# Скопируйте этот файл как .env и заполните значения
# cp .env.example .env

# Токен группы ВКонтакте (Управление → Работа с API → Ключи доступа)
VK_TOKEN=вставьте_токен_группы_вк

# ЮКасса — боевые ключи (Настройки → Ключи API)
YOOKASSA_SHOP_ID=1192660
YOOKASSA_SECRET_KEY=live_ваш_секретный_ключ

# ЮКасса — тестовые ключи (для проверки без реальных денег)
# YOOKASSA_SHOP_ID=1348221
# YOOKASSA_SECRET_KEY=test_ваш_тестовый_ключ
